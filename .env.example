# ── Supabase ────────────────────────────────────────────────────────────────
# Project URL and anon key — safe to expose to the client
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service role key — server-side only, bypasses RLS. Never expose to client.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Anthropic ────────────────────────────────────────────────────────────────
# Required for market generation (refresh-markets cron) and AI resolution fallback.
# If missing, market generation will fail and resolution falls back to majority vote only.
ANTHROPIC_API_KEY=sk-ant-...

# ── Cron security ────────────────────────────────────────────────────────────
# Bearer token required by all cron endpoints and the admin resolve endpoint.
# Generate with: openssl rand -hex 32
CRON_SECRET=your-cron-secret

# ── Web Push (VAPID) ─────────────────────────────────────────────────────────
# Required for push notifications. If missing, push silently no-ops (safe).
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key   # same as VAPID_PUBLIC_KEY

# ── Sentry ───────────────────────────────────────────────────────────────────
# Error tracking. If missing, errors are logged to console only.
SENTRY_DSN=https://...@sentry.io/...
NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...     # same as SENTRY_DSN
SENTRY_AUTH_TOKEN=your-sentry-auth-token             # optional — for source map uploads

# ── Kill switches (optional) ─────────────────────────────────────────────────
# Set to "true" in Vercel dashboard to disable subsystems without a deploy.
# DISABLE_MARKET_GENERATION=true   # halts AI market generation cron
# DISABLE_RESOLUTION=true          # halts automated market resolution
